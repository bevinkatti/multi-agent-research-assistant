# ============================================================
# Multi-Agent AI Research Assistant — .env.example
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- LLM Providers ---
GROQ_API_KEY=your_groq_api_key_here               # https://console.groq.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here     # Fallback only — optional

# --- Web Search ---
TAVILY_API_KEY=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           # https://app.tavily.com

# --- Model Configuration ---
DEFAULT_LLM_PROVIDER=groq                         # "groq" or "anthropic"
GROQ_MODEL_NAME=llama-3.3-70b-versatile
ANTHROPIC_MODEL_NAME=claude-haiku-4-5-20251001

# --- Agent Behavior ---
AGENT_TIMEOUT_SECONDS=30                          # Max seconds per agent call
MAX_RETRIES=3                                     # Retry attempts before failing
RETRY_BASE_DELAY=1.0                              # Seconds; doubles each retry

# --- Vector Store ---
FAISS_INDEX_PATH=./data/faiss_index               # Local path for persisted index
EMBEDDING_MODEL=all-MiniLM-L6-v2                  # sentence-transformers model name
CHUNK_SIZE=512                                    # Characters per chunk
CHUNK_OVERLAP=50                                  # Overlap between chunks

# --- Evaluation ---
EVAL_OUTPUT_PATH=./evaluation/results/benchmark_report.json

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO                                    # DEBUG | INFO | WARNING | ERROR

# --- Streamlit ---
STREAMLIT_PORT=8501
